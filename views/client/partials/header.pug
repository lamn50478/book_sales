include ../layouts/mixins/sub-menu.pug
// views/partials/header.pug
//- Refined header — giữ nguyên các đường dẫn bạn cung cấp
header.header(role="banner" aria-label="Header chính")
  .row.align-items-center
    .col-1
      .inner-logo
        a(href="/" aria-label="Trang chủ")
          img(src="/img/book.png" alt="Ảnh logo" width="64" height="64")
    
    .col-6
      
      .inner-menu
        //- Desktop / tablet menu (pill style)
        ul

          li
            a(href="/")
              | Trang chu
          li
            a(href="/demo")
              | Trang demo
          
          li.sub-menu
            - const pathProduct="/products"
            a(href="/products" aria-haspopup="true" aria-expanded="false")
              | Trang danh sach san pham
              span.caret
            +sub-menu(layoutProductsCategory,pathProduct)

              
          li
            a(href="/admin/dashboard")
              | Trang admin
    .col-3
      form(
        action="/search"
        method="GET"
      )
        div(class="form-group d-flex mb-0 search-bar")
          input(
            class="form-control"
            name="keyword"
            type="text"
            placeholder="Nhập từ khóa"
            value=keyword
          )
          button(type="submit" class="btn btn-primary search-btn" aria-label="Tìm kiếm")
            //- inline SVG magnifier
            svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true")
              circle(cx="11" cy="11" r="6")
              line(x1="21" y1="21" x2="16.65" y2="16.65")
            | Tìm
    .col-1 
      div 
        a(href=`/cart` class="ml-5") Giỏ hàng(#{miniCart?miniCart:"0"}) 
          

          
      //- Mobile toggle (keeps markup simple; JS toggles body.menu-open)
      button.menu-toggle#menuToggle(type="button" aria-expanded="false" aria-controls="mobileMenu" aria-label="Mở menu")
        span.bar
        span.bar
        span.bar

  //- Mobile menu panel (hidden by default; shown when JS adds body.menu-open)
  nav#mobileMenu.mobile-menu(role="navigation" aria-label="Menu di động")
    .mobile-inner
      ul
        li
          a(href="/")
            | Trang chu
        //- Mobile tree uses same .sub-menu class so CSS rules apply consistently
        li.sub-menu
          a(href="/products" aria-haspopup="true" aria-expanded="false")
            | Trang danh sach san pham
            span.caret
          ul
            li
              a(href="/products/slug-1") Mục 1
              ul
                li
                  a(href="/products/slug-1-1") Mục 1-1
                li
                  a(href="/products/slug-1-2") Mục 1-2
                  ul
                    li
                      a(href="/products/slug-1-2-1") Mục 1-2-1
                    li
                      a(href="/products/slug-1-2-2") Mục 1-2-2
            li
              a(href="/products/slug-2") Mục 2

        li
          a(href="/admin/dashboard")
            | Trang admin
        li
          a(href="/admin/products")
            | Trang quan ly san pham admin
        li 
          a(href=`/cart`) Giỏ hàng 
      .mobile-cta
        a.btn.btn-cta(href="/collections/best-sellers") Khám phá sách
//- chèn ngay dưới header.pug hoặc cuối file header
style.
  /* ===== Search button & bar (scoped to header) ===== */
  .header .search-bar {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.85);
    border-radius: 999px;
    padding: 4px;
    border: 1px solid rgba(15,23,42,0.06);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.6);
    transition: box-shadow 220ms ease, transform 220ms ease;
    min-width: 220px;
    max-width: 520px;
    width: 100%;
  }

  .header .search-bar:focus-within {
    box-shadow: 0 8px 30px rgba(124,58,237,0.08);
    transform: translateY(-1px);
  }

  .header .search-bar .form-control {
    border: 0;
    background: transparent;
    padding: 8px 12px;
    font-size: 14px;
    color: var(--header-text, #2f2a24);
    outline: none;
    min-width: 0;
    flex: 1 1 auto;
  }

  .header .search-bar .form-control::placeholder {
    color: rgba(47,42,36,0.45);
  }

  /* Search button: modern pill with icon */
  .header .search-bar .search-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border-radius: 999px;
    border: 0;
    cursor: pointer;
    font-weight: 800;
    font-size: 14px;
    color: #0F172A;
    background: linear-gradient(90deg, #FFB86B 0%, #F59E0B 60%);
    box-shadow: 0 10px 26px rgba(255,184,107,0.18);
    transition: transform 160ms ease, box-shadow 160ms ease, filter 160ms ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;
  }

  .header .search-bar .search-btn:hover {
    transform: translateY(-3px);
    filter: saturate(1.05);
    box-shadow: 0 18px 40px rgba(255,184,107,0.20);
  }

  .header .search-bar .search-btn:active {
    transform: translateY(0);
    box-shadow: 0 8px 18px rgba(255,184,107,0.12);
  }

  /* Small magnifier icon (pure CSS SVG) */
  .header .search-btn svg {
    width: 16px;
    height: 16px;
    display: block;
    flex-shrink: 0;
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.06));
  }

  /* Disabled / loading state (optional) */
  .header .search-btn[disabled] {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
    filter: grayscale(0.2);
  }

  /* Compact mode for small screens */
  @media (max-width: 768px) {
    .header .search-bar {
      min-width: 0;
      max-width: 320px;
      padding: 6px;
    }
    .header .search-bar .form-control { padding: 8px 10px; font-size: 13px; }
    .header .search-bar .search-btn { padding: 8px 10px; font-size: 13px; }
  }

  /* Accessibility focus ring */
  .header .search-bar .search-btn:focus,
  .header .search-bar .form-control:focus {
    outline: 3px solid rgba(124,58,237,0.12);
    outline-offset: 3px;
    border-radius: 999px;
  }
