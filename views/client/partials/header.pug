include ../layouts/mixins/sub-menu.pug
// views/partials/header.pug
//- Refined header — giữ nguyên các đường dẫn bạn cung cấp
header.header(role="banner" aria-label="Header chính")
  .row.align-items-center
    .col-1
      .inner-logo
        a(href="/" aria-label="Trang chủ")
          img(src=SettingGeneral.logo alt="Ảnh logo" width="64" height="64")
    
    .col-5
      .inner-menu
        //- Desktop / tablet menu (pill style)
        ul
          li
            a(href="/")
              | Trang chủ
          if(user)
            li
              a(href="/user/infor")
                | Hồ sơ
          
          li.sub-menu
            - const pathProduct="/products"
            a(href="/products" aria-haspopup="true" aria-expanded="false")
              | Sản phẩm
              span.caret
            +sub-menu(layoutProductsCategory,pathProduct)

          li
            a(href="/admin/dashboard")
              | Trang admin
      
          if(user)
            li 
              a(href="/chat") Chat
            li  
              a(href="/user/logout") 
                | Đăng xuất
          else 
            li  
              a(href="/user/login") 
                | Đăng nhập
            li  
              a(href="/user/register") 
                | Đăng kí
    .col-3
      form(
        action="/search"
        method="GET"
      )
        div(class="form-group d-flex mb-0 search-bar")
          input(
            class="form-control"
            name="keyword"
            type="text"
            placeholder="Nhập từ khóa"
            value=keyword
          )
          button(type="submit" class="btn btn-primary search-btn" aria-label="Tìm kiếm")
            svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true")
              circle(cx="11" cy="11" r="6")
              line(x1="21" y1="21" x2="16.65" y2="16.65")
            | Tìm

    //- ── GIỎ HÀNG ─────────────────────────────────────────
    .col-2.d-flex.align-items-center.justify-content-end
      a.header-cart-pill(
        href="/cart"
        aria-label=`Giỏ hàng – ${miniCart ? miniCart : 0} sản phẩm`
        title="Xem giỏ hàng"
      )
        //- Icon túi
        span.hcp-icon(aria-hidden="true")
          svg(viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round")
            path(d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z")
            line(x1="3" y1="6" x2="21" y2="6")
            path(d="M16 10a4 4 0 0 1-8 0")
        //- Text block
        span.hcp-text
          span.hcp-label Giỏ hàng
          span.hcp-sub #{miniCart && miniCart > 0 ? miniCart + ' sản phẩm' : 'Trống'}
        //- Badge
        span.hcp-badge(
          aria-hidden="true"
          class=(miniCart && miniCart > 0 ? '' : 'hcp-badge--empty')
        ) #{miniCart ? miniCart : 0}

      //- Mobile toggle
      button.menu-toggle#menuToggle(type="button" aria-expanded="false" aria-controls="mobileMenu" aria-label="Mở menu")
        span.bar
        span.bar
        span.bar

  //- Mobile menu panel
  nav#mobileMenu.mobile-menu(role="navigation" aria-label="Menu di động")
    .mobile-inner
      ul
        li
          a(href="/") Trang chủ
        li.sub-menu
          a(href="/products" aria-haspopup="true" aria-expanded="false")
            | Sản phẩm
            span.caret
          ul
            li
              a(href="/products/slug-1") Mục 1
              ul
                li
                  a(href="/products/slug-1-1") Mục 1-1
                li
                  a(href="/products/slug-1-2") Mục 1-2
                  ul
                    li
                      a(href="/products/slug-1-2-1") Mục 1-2-1
                    li
                      a(href="/products/slug-1-2-2") Mục 1-2-2
            li
              a(href="/products/slug-2") Mục 2
        li
          a(href="/admin/dashboard") Trang admin
        li
          a(href="/admin/products") Quản lý sản phẩm

        //- Mobile cart row
        li
          a.header-cart.header-cart--mobile(href="/cart" aria-label="Giỏ hàng")
            span.header-cart-icon(aria-hidden="true")
              svg(viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
                path(d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z")
                line(x1="3" y1="6" x2="21" y2="6")
                path(d="M16 10a4 4 0 0 1-8 0")
            span Giỏ hàng
            span.header-cart-badge(
              class=(miniCart && miniCart > 0 ? '' : 'header-cart-badge--empty')
            ) #{miniCart ? miniCart : 0}

      .mobile-cta
        a.btn.btn-cta(href="/collections/best-sellers") Khám phá sách

//- ── SCOPED STYLES (search bar + cart icon) ─────────────
style.
  /* ===== Search button & bar ===== */
  .header .search-bar {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.85);
    border-radius: 999px;
    padding: 4px;
    border: 1px solid rgba(15,23,42,0.06);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.6);
    transition: box-shadow 220ms ease, transform 220ms ease;
    min-width: 220px;
    max-width: 520px;
    width: 100%;
  }
  .header .search-bar:focus-within {
    box-shadow: 0 8px 30px rgba(124,58,237,0.08);
    transform: translateY(-1px);
  }
  .header .search-bar .form-control {
    border: 0;
    background: transparent;
    padding: 8px 12px;
    font-size: 14px;
    color: var(--header-text, #2f2a24);
    outline: none;
    min-width: 0;
    flex: 1 1 auto;
  }
  .header .search-bar .form-control::placeholder { color: rgba(47,42,36,0.45); }
  .header .search-bar .search-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border-radius: 999px;
    border: 0;
    cursor: pointer;
    font-weight: 800;
    font-size: 14px;
    color: #0F172A;
    background: linear-gradient(90deg, #FFB86B 0%, #F59E0B 60%);
    box-shadow: 0 10px 26px rgba(255,184,107,0.18);
    transition: transform 160ms ease, box-shadow 160ms ease, filter 160ms ease;
    white-space: nowrap;
  }
  .header .search-bar .search-btn:hover {
    transform: translateY(-3px);
    filter: saturate(1.05);
    box-shadow: 0 18px 40px rgba(255,184,107,0.20);
  }
  .header .search-bar .search-btn:active {
    transform: translateY(0);
    box-shadow: 0 8px 18px rgba(255,184,107,0.12);
  }
  .header .search-btn svg {
    width: 16px;
    height: 16px;
    display: block;
    flex-shrink: 0;
  }
  .header .search-btn[disabled] {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
    filter: grayscale(0.2);
  }
  @media (max-width: 768px) {
    .header .search-bar { min-width: 0; max-width: 320px; padding: 6px; }
    .header .search-bar .form-control { padding: 8px 10px; font-size: 13px; }
    .header .search-bar .search-btn { padding: 8px 10px; font-size: 13px; }
  }
  .header .search-bar .search-btn:focus,
  .header .search-bar .form-control:focus {
    outline: 3px solid rgba(124,58,237,0.12);
    outline-offset: 3px;
    border-radius: 999px;
  }
