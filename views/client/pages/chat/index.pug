extends ../../layouts/default.pug
include ../../layouts/mixins/box-head.pug
include ../../layouts/mixins/product-layout.pug
include ../../layouts/mixins/alert.pug


block head
    link(rel="stylesheet" href="/css/chat2.css")
    link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/viewerjs/1.11.7/viewer.css")

    

block main
    +alert-success(4000)
    +alert-error(4000)

    .container.my-5
        include ../../partials/list-btn-user.pug
        .row
            .col-12
                +box-head("chat")
        .row
            .col-12
                .chat(my-id=user.id my-fullname=user.fullName)
                    .inner-body
                        each chat in chats
                            div(class=(chat.user_id==user.id ? "inner-outgoing" : "inner-coming"))
                                if chat.user_id != user.id && chat.inforUser && chat.inforUser.fullName
                                    .inner-name #{chat.inforUser.fullName}
                                if chat.content
                                    .inner-content #{chat.content}
                                if chat.images 
                                    .inner-images 
                                        each image in chat.images 
                                            img(src=image)
                        div(class="inner-list-typing")
                    .inner-preview-images 
                        div(class="custom-file-container" data-upload-id="upload-image")     
                    .inner-foot
                        form.inner-form(action="" method="post")
                            input(type="text" name="content" placeholder="Nhập nội dung..." aria-label="Nội dung tin nhắn")
                            //- div(class="custom-file-container" data-upload-id="upload-image") 
                            label(for="file-upload-with-preview-upload-image" class=" btn btn-light mx-2 mb-0 " ) 
                                <i class="fa-solid fa-image"></i>
                            span.button-icon.btn.btn-light.mx-2.mb-0  
                                i(class="fa-regular fa-face-grin-tongue")
                            button
                                i.fa-solid.fa-paper-plane
    
    div(class="tooltip" role="tooltip")
        emoji-picker(class="dark")
  
    <script type="module" src="https://cdnjs.cloudflare.com/ajax/libs/viewerjs/1.11.7/viewer.js"></script>
    block script 
        <script src="/socket.io/socket.io.js"></script>
        <script src="/js/socket.js"></script>
        <script type="module" src="/js/chat.js"></script>