extends ../../layouts/default.pug
include ../../layouts/mixins/box-head.pug
include ../../layouts/mixins/product-layout.pug
include ../../layouts/mixins/alert.pug

block main
  //- Embedded CSS
  style.
    :root{
      --bg: #f3f4f6;
      --card-bg: #ffffff;
      --muted: #6b7280;
      --accent: #4f46e5;
      --accent-2: #06b6d4;
      --glass: rgba(255,255,255,0.6);
      --radius: 12px;
      --transition: 180ms cubic-bezier(.2,.9,.2,1);
      --max-width: 1200px;
      font-family: "Inter", "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      color-scheme: light;
    }

    .auth-wrapper{
      position: fixed;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(180deg, #eef2ff 0%, var(--bg) 60%);
      padding: 2rem;
      box-sizing: border-box;
      overflow: auto;
    }

    .auth-split-card{
      width: 100%;
      max-width: var(--max-width);
      height: calc(100vh - 4rem);
      display: flex;
      border-radius: calc(var(--radius) + 4px);
      overflow: hidden;
      background: transparent;
      box-shadow: 0 10px 30px rgba(15,23,42,0.08);
      border: 1px solid rgba(15,23,42,0.04);
    }

    .auth-left{
      flex: 1 1 55%;
      min-width: 360px;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      background: linear-gradient(180deg, rgba(2,6,23,0.06), rgba(2,6,23,0.06));
    }

    .auth-left-img{
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      filter: saturate(1.02) contrast(1.02) brightness(0.95);
      transition: transform 8s ease;
    }

    .auth-left:hover .auth-left-img{ transform: scale(1.03) translateY(-3%); }

    .auth-left::after{
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(2,6,23,0.28) 0%, rgba(2,6,23,0.18) 40%, rgba(2,6,23,0.36) 100%);
      mix-blend-mode: multiply;
    }

    .brand-wrap{ position: relative; z-index: 2; text-align: center; color: #fff; padding: 3rem 2rem; }

    .brand-title{ font-weight: 800; font-size: 2rem; color: #fff; text-shadow: 0 10px 30px rgba(2,6,23,0.45); }

    .auth-right{
      flex: 1 1 45%;
      min-width: 320px;
      height: 100%;
      padding: 3.2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(180deg, rgba(255,255,255,0.6), rgba(255,255,255,0.9));
    }

    .auth-card{
      width: 100%;
      max-width: 480px;
      background: var(--card-bg);
      border-radius: var(--radius);
      padding: 2.25rem;
      box-shadow: 0 12px 30px rgba(15,23,42,0.06);
      border: 1px solid rgba(15,23,42,0.04);
    }

    .auth-card h1{ font-size: 1.5rem; margin-bottom: 0.25rem; color: #0f172a; font-weight: 700; }

    .auth-card p.lead{ margin-bottom: 1.25rem; color: var(--muted); font-size: 0.98rem; }

    .form-vertical-gap > .form-group{ margin-bottom: 1rem; }

    .form-group label{ color: #374151; font-size: 0.95rem; margin-bottom: 0.5rem; font-weight: 600; display: block; }

    .form-control{
      width: 100%;
      background: #fff;
      border: 1px solid rgba(15,23,42,0.08);
      padding: 0.75rem 0.9rem;
      border-radius: 10px;
      transition: box-shadow var(--transition), border-color var(--transition);
      font-size: 0.98rem;
    }

    .form-control:focus{ border-color: rgba(79,70,229,0.95); box-shadow: 0 12px 30px rgba(79,70,229,0.08); }

    .btn-primary{
      background: linear-gradient(90deg, var(--accent) 0%, var(--accent-2) 100%);
      border: none;
      padding: 0.85rem 1rem;
      font-weight: 700;
      border-radius: 10px;
      color: #fff;
      width: 100%;
      cursor: pointer;
      font-size: 1rem;
    }

    .btn-primary:hover{ transform: translateY(-3px); }

    .small-muted{ margin-top: 1rem; font-size: 0.85rem; color: #9ca3af; text-align: center; }

  //- Markup
  +alert-success(4000)
  +alert-error(4000)
  .auth-wrapper
    .auth-split-card
      .auth-left
        img.auth-left-img(src=(typeof imageSrc !== 'undefined' ? imageSrc : '/uploads/Young-Children-Reading-Books.jpg') alt='Illustration')
        .brand-wrap
          .brand-title Hệ thống bán sách
          .brand-sub Đăng ký để tham gia cộng đồng đọc sách

      .auth-right
        .auth-card
          
          h1 Đăng ký
          p.lead Tạo tài khoản để trải nghiệm dịch vụ
          form(action="/user/register" method="POST" class="form-vertical-gap")
            .form-group
              label(for="fullName") Họ và tên *
              input#fullName.form-control(type="text" name="fullName" placeholder="Nguyễn Văn A")
            .form-group
              label(for="email") Email *
              input#email.form-control(type="email" name="email" placeholder="you@example.com" )
            .form-group
              label(for="password") Mật khẩu *
              input#password.form-control(type="password" name="password" placeholder="Mật khẩu của bạn" )
            .form-group
              button.btn.btn-primary(type="submit") Đăng ký
            .form-help.text-center
              | Đã có tài khoản?
              a(href=`${prefixAdmin}/auth/login` class="text-decoration-none" style="color: var(--accent); margin-left: 6px;") Đăng nhập
          .small-muted Bằng việc đăng ký bạn đồng ý với điều khoản và chính sách bảo mật.
