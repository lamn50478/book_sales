mixin table-tree(items,level=1) 
    each item, index in items 
        - const prefix= Array(level + 1).join("-- ")
        tr 
            td 
                input(type="checkbox" name="id" value=item.id)
            td #{item.index}
            td 
                .inner-image 
                    img(
                    src=item.thumbnail
                    alt=item.title
                    style="width: 100px; height:auto"
                    )
            td #{prefix}#{item.title}
            td 
                input(
                    type="number",
                    style="width:60px",
                    min=1,
                    value=item.position,
                    name='position'

            )
            td 
                if item.status == "active"
                    a(
                    data-status=item.status
                    data-id=item._id
                    button-change-status
                    href=`javascript:;`
                    class="badge badge-success") Hoạt động 
                else 
                    a(
                    data-status=item.status
                    data-id=item._id
                    button-change-status
                    href=`javascript:;`
                    class="badge badge-danger") Không hoạt động 
            td 
                if(role.permission.includes("products_category_view"))
                    a(
                        class="btn btn-secondary btn-sm"
                        href=`${prefixAdmin}/products-category/detail/${item.id}`
                        ) Chi tiết
                if(role.permission.includes("products_category_edit"))         
                    a(
                        class="btn btn-warning btn-sm ml-1"
                        href=`${prefixAdmin}/products-category/edit/${item.id}`
                        ) Sửa
                if(role.permission.includes("products_category_delete"))
                    button(
                        class="btn btn-danger btn-sm ml-1"
                        button-delete 
                        data-id=item.id
                        ) Xóa
        if item.children && item.children.length > 0 
            +table-tree(item.children, level +1)

