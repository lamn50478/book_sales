extends ../../layouts/default.pug 

block main 
    if(role.permission.includes("role_edit"))
        h1(class="mb-3") Chỉnh sửa nhóm quyền
        form(
        action=`${prefixAdmin}/role/edit/${data.id}?_method=PATCH`
        method="POST" 
    )
            div(class="form-group")
                label(for="title") Tiêu đề
                input(
                    name="title"
                    id="title"
                    type="text"
                    class="form-control"
                    value=data.title
                    
                ) 
            div(class="form-group")
                label(for="desc") Mô tả
                input(
                    name="description"
                    id="desc"
                    type="text"
                    class="form-control"
                    value=data.description
                    
                ) 
            div(class="form-group")
                button(
                    type="submit"
                    class=" btn btn-outline-primary"
                ) Chỉnh sửa
            
                            

            