extends ../../layouts/default.pug
include ../../mixins/alert.pug
block main
    +alert-error(5000)
    +alert-success(5000)
    if(role.permission.includes("account_view")) 
        h1(class="mb-4") Danh sách tài khoản 

        .card.mb-3 
            .card-header Danh sách 
            .card-body 
                .row 
                    .col-8 
                    .col-4.text-right 
                        if(role.permission.includes("account_create"))
                            a(
                                href=`${prefixAdmin}/accounts/create`
                                class="btn btn-outline-success"
                            ) + Thêm mới
            table(class="table-hover table-sm table")
                thead 
                    tr 
                        th STT 
                        th Avatar 
                        th Họ tên 
                        th Phân quyền
                        th Email 
                        th Trạng thái 
                        th Hành động 
                tbody 
                    each item,index  in records
                        tr 
                            td #{index+1}
                            td 
                                img(
                                    src=item.avatar
                                    alt=item.title 
                                    width ="100px"
                                    height="auto"
                                )
                            td #{item.fullName}
                            td
                                if item.role && item.role.title
                                    | #{item.role.title}
                                else
                                    | Chưa phân quyền
                            td #{item.email}
                            td 
                                if(item.status=="active") 
                                    a(
                                        href="javascript:;" 
                                        class="badge badge-success"
                                        data-status="active"
                                    ) Hoạt động 
                                else 
                                    a(
                                        href="javascript:;"
                                        class="badge badge-danger"
                                        data-status="inactive"
                                    ) Dừng hoạt động 
                            td 
                                if(role.permission.includes("account_view"))
                                    a(
                                        class="btn btn-secondary btn-sm "
                                        href=`${prefixAdmin}/accounts/detail/${item.id}`
                                    ) Chi tiết 
                                if(role.permission.includes("account_edit"))
                                    a(
                                        class="btn btn-warning btn-sm ml-1"
                                        href=`${prefixAdmin}/accounts/edit/${item.id}`
                                    ) Sửa 
                                if(role.permission.includes("account_delete"))
                                    a(
                                        class="btn btn-danger btn-sm ml-1"
                                        href=`${prefixAdmin}/accounts/delete/${item.id}`
                                    ) Xóa 
        style.
            .avatar-thumb {
            display: inline-block;
            width: 80px;
            height: 80px;
            object-fit: cover;
            border-radius: 6px;
            border: 1px solid #e9e9e9;
            background-color: #f6f6f6;
            }

            /* nếu muốn kích thước nhỏ hơn trên mobile */
            @media (max-width: 576px) {
            .avatar-thumb {
                width: 56px;
                height: 56px;
            }
            }