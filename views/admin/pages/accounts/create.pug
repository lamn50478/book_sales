extends ../../layouts/default.pug
include ../../mixins/alert.pug 

block main 
    if(role.permission.includes("account_create"))
        h1(class="mb-4") Thêm mới tài khoản
        +alert-error(5000)
        
        form(
            action=`${prefixAdmin}/accounts/create`
            method="POST"
            enctype="multipart/form-data"
        )
            div(class="form-group")
                label(for="fullName") Họ và tên *
                input(
                    type="text"
                    class="form-control"
                    id="fullName"
                    name="fullName" 
                    required
                )

            div(class="form-group")
                label(for="email") Email *
                input(
                    type="text"
                    class="form-control"
                    id="email"
                    name="email" 
                    required
                )

            div(class="form-group")
                label(for="password") Mật khẩu *
                input(
                    type="text"
                    class="form-control"
                    id="password"
                    name="password" 
                    required
                )
            
            div(class="form-group")
                label(for="phone") Số điện thoại
                input(
                    type="number"
                    class="form-control"
                    id="phone"
                    name="phone" 
                    
                )

            
            div(
                class="form-group"
                upload-image 
            )
                label(
                    for="avatar"
                ) Avatar 
                input(
                    type="file"
                    class="form-control-file"
                    id="avatar"
                    name ="avatar"
                    accept ="imagte/*"
                    upload-image-input 

                )
                img(
                    src=""
                    class="image-review"
                    upload-image-review
                )
            div(class="form-group")
                label(for="role_id") Phân quyền
                select(name="role_id" id="role_id" class="custom-select mb-3")
                    option(disabled selected) --Chọn--
                    each item in roles 
                        option(value=item.id) #{item.title}

            div(class="form-check form-check-inline form-group")
                input(
                    type="radio"
                    name= "status"
                    id ="statusActive"
                    class="form-check-input"
                    value="active"
                    checked
                )
                label(for="statusActive" class="form-check-label") Hoạt động
            div(class="form-check form-check-inline form-group")
                input(
                    type="radio"
                    name= "status"
                    id ="statusInactive"
                    class="form-check-input"
                    value="inactive"
                    
                )
                label(for="statusInactive" class="form-check-label") Dừng hoạt động 
            div(class="form-group") 
                button(
                    type="submit"
                    class="btn btn-primary"
                ) Tạo mới
